{
  "name": "healthybite-mobile",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "HealthyBite Native Mobile App — Capacitor wrapper",
  "scripts": {
    "build": "cd ../client && npm run build",
    "sync": "npx cap sync",
    "add:android": "npx cap add android",
    "add:ios": "npx cap add ios",
    "open:android": "npx cap open android",
    "open:ios": "npx cap open ios",
    "build:apk": "cd android && ./gradlew assembleDebug && cp app/build/outputs/apk/debug/app-debug.apk \"../../client/public/downloads/HealthyBite-Android.apk\"",
    "build:android": "cd ../client && npm run build && cd ../app && npx cap sync && npm run build:apk",
    "build:ios": "cd ../client && npm run build && cd ../app && npx cap sync && npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
