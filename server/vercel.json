{
  "version": 2,
  "builds": [{ "src": "api/index.js", "use": "@vercel/node" }],
  "routes": [
    { "src": "/auth(.*)", "dest": "api/index.js" },
    { "src": "/products(.*)", "dest": "api/index.js" },
    { "src": "/orders(.*)", "dest": "api/index.js" },
    { "src": "/users(.*)", "dest": "api/index.js" },
    { "src": "/plans(.*)", "dest": "api/index.js" },
    { "src": "/testimonials(.*)", "dest": "api/index.js" },
    { "src": "/dashboard(.*)", "dest": "api/index.js" },
    { "src": "/health", "dest": "api/index.js" },
    { "src": "/faq(.*)", "dest": "api/index.js" },
    { "src": "/settings(.*)", "dest": "api/index.js" },
    { "src": "/uploads(.*)", "dest": "api/index.js" },
    { "src": "/otp(.*)", "dest": "api/index.js" },
    { "src": "/coupons(.*)", "dest": "api/index.js" },
    { "src": "/webhook(.*)", "dest": "api/index.js" },
    { "src": "/chat(.*)", "dest": "api/index.js" },
    { "src": "/ai(.*)", "dest": "api/index.js" },
    { "src": "/mobile(.*)", "dest": "api/index.js" },
    { "src": "/api/download(.*)", "dest": "api/index.js" }
  ]
}
